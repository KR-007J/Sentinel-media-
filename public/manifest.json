{
  "manifest_version": 3,
  "name": "Sentinel-Zero",
  "version": "1.0.0",
  "description": "Cyber-Security War Room Dashboard and Digital Asset Guardian",
  "action": {
    "default_title": "Launch Sentinel-Zero"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
