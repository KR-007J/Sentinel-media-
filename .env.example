# ─────────────────────────────────────────────
# Sentinel-Media — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Google Gemini API (required for AI analysis)
# Get key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase / Firestore (optional — app works without it in local mode)
# Get from: https://console.firebase.google.com → Project Settings → Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─────────────────────────────────────────────
# Deployment Notes:
# Vercel: Add all VITE_* vars in Dashboard → Project → Settings → Env Vars
# Render: Add in Dashboard → Service → Environment
# Firebase Hosting: Use .env during build, vars are embedded at build time
# ─────────────────────────────────────────────
